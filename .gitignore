# ============================================
# Abogada Guerra · Sitio Web
# .gitignore — Potencia Empresarial
# ============================================

# ---- Sistema operativo ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---- IDEs y editores ----
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
*.sublime-project
*.sublime-workspace

# ---- Claude Code / herramientas IA ----
.claude/
.cursor/

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Dependencias (si en futuro se agrega build) ----
node_modules/
bower_components/
vendor/

# ---- Build outputs (si se agrega bundler) ----
dist/
build/
.cache/
.parcel-cache/
.next/
.nuxt/

# ---- Variables de entorno y secretos ----
.env
.env.local
.env.development
.env.production
.env.*.local
*.pem
*.key
secrets.json
config.local.json

# ---- Backups y temporales ----
*.bak
*.backup
*.tmp
*.old
*~
*.orig

# ---- Netlify (algunos archivos locales) ----
.netlify/

# ---- Tests / coverage ----
coverage/
*.lcov
.nyc_output/

# ---- ZIPs y archivos comprimidos del proyecto ----
*.zip
*.tar.gz
*.rar

# ---- Documentación interna que NO va al repo ----
# (las guías de deploy y docs están dentro de /sitio_web pero queremos compartirlas)
# DEPLOY_AHORA.md  ← este SÍ se incluye en el repo
# DEPLOY_NETLIFY.md ← este SÍ
# README.md         ← este SÍ

# ---- macOS / Linux específicos ----
$RECYCLE.BIN/
.AppleDouble
.LSOverride

# ---- Archivos generados por el preview server local ----
preview-*.log
